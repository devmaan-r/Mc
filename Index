<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>RGB Blinking Text</title>

<style>
body{
    margin:0;
    display:flex;
    justify-content:center;
    align-items:center;
    height:100vh;
    background:#000;
    overflow:hidden;
    font-family:Arial, sans-serif;
}

h1{
    font-size:3rem;
    text-align:center;
    animation: rgbBlink 0.5s infinite;
}

@keyframes rgbBlink{
    0%{
        color:red;
        text-shadow:0 0 20px red;
    }
    33%{
        color:lime;
        text-shadow:0 0 20px lime;
    }
    66%{
        color:blue;
        text-shadow:0 0 20px blue;
    }
    100%{
        color:red;
        text-shadow:0 0 20px red;
    }
}
</style>

</head>
<body>

<h1>Jo Mila h usse khus raho madarchod</h1>

</body>
</html>
